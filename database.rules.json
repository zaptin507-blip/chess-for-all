{
  "rules": {
    "online-games": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$gameId": {
        ".read": "auth != null && (data.child('players').child('white').child('uid').val() === auth.uid || data.child('players').child('black').child('uid').val() === auth.uid)",
        ".write": "auth != null && (newData.child('players').child('white').child('uid').val() === auth.uid || data.child('players').child('black').child('uid').val() === auth.uid || (!data.child('players').child('black').exists() && newData.child('players').child('black').child('uid').val() === auth.uid))",
        "moves": {
          ".read": "auth != null && (root.child('online-games').child($gameId).child('players').child('white').child('uid').val() === auth.uid || root.child('online-games').child($gameId).child('players').child('black').child('uid').val() === auth.uid)",
          ".write": "auth != null && (root.child('online-games').child($gameId).child('players').child('white').child('uid').val() === auth.uid || root.child('online-games').child($gameId).child('players').child('black').child('uid').val() === auth.uid)"
        },
        "chat": {
          ".read": "auth != null && (root.child('online-games').child($gameId).child('players').child('white').child('uid').val() === auth.uid || root.child('online-games').child($gameId).child('players').child('black').child('uid').val() === auth.uid)",
          ".write": "auth != null && (root.child('online-games').child($gameId).child('players').child('white').child('uid').val() === auth.uid || root.child('online-games').child($gameId).child('players').child('black').child('uid').val() === auth.uid)"
        },
        "drawOffer": {
          ".read": "auth != null && (root.child('online-games').child($gameId).child('players').child('white').child('uid').val() === auth.uid || root.child('online-games').child($gameId).child('players').child('black').child('uid').val() === auth.uid)",
          ".write": "auth != null && (root.child('online-games').child($gameId).child('players').child('white').child('uid').val() === auth.uid || root.child('online-games').child($gameId).child('players').child('black').child('uid').val() === auth.uid)"
        }
      }
    },
    "game-chats": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "tester-reminders": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
